# Copy to .env and fill in values
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string

# RDS values from Terraform output
DB_HOST=your-rds-endpoint-here.rds.amazonaws.com
DB_PORT=5432
DB_NAME=mydatabase
DB_USER=avi
DB_PASSWORD=Avi12345
DB_SSL=true

# Frontend URL for CORS (your EC2 public IP or domain)
FRONTEND_URL=http://your-ec2-ip
